# open-memory configuration

# Path to QMD binary (default: qmd, assumes it's in PATH)
# QMD_BIN=/path/to/qmd

# Memory directory - where your MEMORY.md and memory/*.md files live
# MEMORY_DIR=~/.openclaw

# Daily notes subdirectory within MEMORY_DIR
# DAILY_NOTES_DIR=memory

# Main memory file name
# MAIN_MEMORY_FILE=MEMORY.md

# QMD collection to search (empty = search all collections)
# QMD_COLLECTION=workspace

# Server port (for HTTP/SSE mode)
# PORT=3838

# Bearer token for auth (leave empty to disable auth)
# OPEN_MEMORY_TOKEN=your-secret-token-here
